---
// =============================================================
// FeaturedCategories.astro · Bloco editorial de destaques
// -------------------------------------------------------------
// Grid assimétrico 60/40 (7/12 + 5/12) no modelo New Yorker:
//
//   ┌──────────────────────┬──────────────┐
//   │                      │  post 2      │
//   │     POST DESTAQUE    │  (Divã Inf.) │
//   │     Outras Histórias │──────────────│
//   │     (imagem 4:5)     │  post 3      │
//   │                      │  (Divã Inf.) │
//   └──────────────────────┴──────────────┘
//
// O componente é puro de apresentação: recebe `featured` e
// `secondary` via props. Sem props, cai em fake data editorial.
// A tipagem é compatível com PostPreview do Sanity, então a
// integração real é um mapeamento simples (veja exemplo no final).
// =============================================================

export interface FeaturedPost {
  categoryTitle: string; // Ex.: "Outras Histórias"
  title: string;
  excerpt?: string | null;
  href: string;
  imageUrl?: string | null;
  imageAlt?: string | null;
}

export interface Props {
  featured?: FeaturedPost;
  secondary?: [FeaturedPost, FeaturedPost];
  heading?: string; // Título pequeno acima do bloco · default "Em destaque"
}

// -------------------------------------------------------------
// Fake data (remover quando a home passar dados do Sanity)
// -------------------------------------------------------------
const FAKE_FEATURED: FeaturedPost = {
  categoryTitle: "Outras Histórias",
  title: "Quando o silêncio torna-se a última forma de cuidado",
  excerpt:
    "Uma reflexão sobre presença, escuta e os gestos que permanecem quando as palavras já não bastam.",
  href: "/outras-historias/silencio-ultima-forma",
  imageUrl: null,
  imageAlt: "Fotografia editorial",
};

const FAKE_SECONDARY: [FeaturedPost, FeaturedPost] = [
  {
    categoryTitle: "Divã Infinito",
    title: "Episódio 14 · Dor total, conforto integral",
    excerpt: "Ana Lúcia Freire desdobra o legado de Cicely Saunders.",
    href: "/diva-infinito/ep-14-dor-total",
    imageUrl: null,
    imageAlt: "Capa do podcast",
  },
  {
    categoryTitle: "Divã Infinito",
    title: "Episódio 13 · Como conversar com crianças sobre perda",
    excerpt: "Uma conversa com a psicóloga Beatriz Amaro.",
    href: "/diva-infinito/ep-13-criancas-perda",
    imageUrl: null,
    imageAlt: "Capa do podcast",
  },
];

const {
  featured = FAKE_FEATURED,
  secondary = FAKE_SECONDARY,
  heading = "Em destaque",
} = Astro.props;
---

<section class="max-w-7xl mx-auto px-6 lg:px-12 py-16 lg:py-24">
  {/* Cabeçalho da seção · título centralizado entre hairlines 1px */}
  <div class="flex items-center gap-6 mb-12 lg:mb-16">
    <span class="flex-1 h-px bg-rule"></span>
    <h2 class="meta">{heading}</h2>
    <span class="flex-1 h-px bg-rule"></span>
  </div>

  {/* Grid assimétrico · 7/12 (≈58%) + 5/12 (≈42%) */}
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14">
    {/* ============================================================
       COLUNA ESQUERDA · Post em destaque (Outras Histórias)
       Bloco envolto em border 1px · imagem vertical 4:5 · título XXL
       ============================================================ */}
    <article
      class="lg:col-span-7 border border-rule p-6 sm:p-8 lg:p-10 group"
    >
      <a href={featured.href} class="block">
        {
          featured.imageUrl ? (
            <img
              src={featured.imageUrl}
              alt={featured.imageAlt ?? featured.title}
              class="w-full aspect-[4/5] object-cover transition-[filter] duration-300 group-hover:brightness-[0.96]"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div
              class="ph w-full aspect-[4/5]"
              data-label="Imagem editorial · 4:5"
            />
          )
        }

        <span class="meta text-amber mt-8 block">
          {featured.categoryTitle}
        </span>

        <h3
          class="font-serif text-3xl sm:text-4xl lg:text-5xl xl:text-[52px] leading-[1.05] mt-4 font-normal transition-colors group-hover:text-amber"
        >
          {featured.title}
        </h3>

        {
          featured.excerpt && (
            <p class="font-serif italic text-lg lg:text-xl leading-snug mt-6 text-ink/75">
              {featured.excerpt}
            </p>
          )
        }
      </a>
    </article>

    {/* ============================================================
       COLUNA DIREITA · Dois posts empilhados (Divã Infinito)
       Imagens 3:2 · títulos médios · separador 1px entre eles
       ============================================================ */}
    <div class="lg:col-span-5 flex flex-col">
      {
        secondary.map((post, i) => (
          <article
            class:list={[
              "group",
              i === 0 && "pb-10",
              i === 1 && "pt-10 border-t border-rule",
            ]}
          >
            <a
              href={post.href}
              class="grid grid-cols-5 gap-5 lg:gap-6 items-start"
            >
              {/* Imagem 3:2 · ocupa 2 de 5 colunas internas */}
              <div class="col-span-2">
                {post.imageUrl ? (
                  <img
                    src={post.imageUrl}
                    alt={post.imageAlt ?? post.title}
                    class="w-full aspect-[3/2] object-cover transition-[filter] duration-300 group-hover:brightness-[0.96]"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div
                    class="ph w-full aspect-[3/2]"
                    data-label="3:2"
                  />
                )}
              </div>

              {/* Texto · 3 de 5 colunas */}
              <div class="col-span-3">
                <span class="meta text-amber block">
                  {post.categoryTitle}
                </span>
                <h3 class="font-serif text-xl lg:text-2xl leading-tight mt-2 font-normal transition-colors group-hover:text-amber">
                  {post.title}
                </h3>
                {post.excerpt && (
                  <p class="text-[14px] leading-snug mt-3 text-ink/70">
                    {post.excerpt}
                  </p>
                )}
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

