---
// =============================================================
// LongEssayHighlight.astro · Ensaio longo destacado na home
// -------------------------------------------------------------
// Reproduz o tratamento editorial das páginas internas já na
// home, dando uma amostra de "como se lê" no portal.
// Estrutura: eyebrow + título centralizado + byline + dropcap
// no primeiro parágrafo + CTA "Continuar lendo →".
// =============================================================

export interface Props {
  eyebrow?: string;
  title?: string;
  byline?: string;
  paragraphs?: string[];
  href?: string;
}

const {
  eyebrow = "Ensaio longo · Outras Histórias",
  title = "O tempo que resta: notas sobre esperança realista",
  byline = "Padre João Ribeiro · 18 min",
  paragraphs = [
    "Quando fui chamado pela primeira vez a acompanhar uma família em cuidados paliativos, pensei que meu papel seria consolar. Levei alguns anos para entender que o verdadeiro trabalho era outro, e muito mais silencioso: o de acompanhar sem pressa, sem respostas prontas, sem a urgência de preencher cada pausa com palavras bem intencionadas.",
    "A esperança realista não nega a finitude — ela habita o tempo que ainda resta com dignidade, atenção e presença. Essa foi a primeira lição que aprendi com pacientes, cuidadores e, sobretudo, com o silêncio dos quartos de hospital ao amanhecer…",
  ],
  href = "/outras-historias/tempo-que-resta",
} = Astro.props;
---

<section class="max-w-3xl mx-auto px-6 py-24 lg:py-32">
  <header class="text-center">
    <span class="meta text-amber">{eyebrow}</span>
    <h2
      class="font-serif text-4xl sm:text-5xl lg:text-6xl leading-[1.05] mt-6 font-normal"
    >
      <a href={href} class="transition-colors hover:text-amber">{title}</a>
    </h2>
    <div class="meta mt-6">{byline}</div>
    <div class="mx-auto mt-8 w-16 h-px bg-ink/30"></div>
  </header>

  {
    paragraphs.map((p, i) => (
      <p
        class:list={[
          "font-serif text-[19px] leading-[1.75]",
          i === 0 ? "dropcap mt-12" : "mt-6",
        ]}
      >
        {p}
      </p>
    ))
  }

  <div class="text-center mt-12">
    <a href={href} class="meta link-ed text-amber">Continuar lendo →</a>
  </div>
</section>
