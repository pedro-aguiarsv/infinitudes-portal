---
// =============================================================
// [category].astro · Listagem por categoria
// -------------------------------------------------------------
// Gera uma página estática para cada uma das 7 seções do portal.
// Cada página carrega os posts vinculados àquela categoria via
// getPostsByCategory() e renderiza em um grid editorial 3-col.
// =============================================================
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PostCard from "../components/PostCard.astro";
import { CATEGORIES, getCategory } from "../lib/categories";
import { getPostsByCategory } from "../lib/sanity";

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { category: cat.value },
    props: { categoryValue: cat.value },
  }));
}

const { categoryValue } = Astro.props as { categoryValue: string };
const category = getCategory(categoryValue)!;
const posts = await getPostsByCategory(categoryValue);
---

<Layout
  title={`${category.title} — InFinitudes`}
  description={category.description}
>
  <Header />

  <main>
    {/* Cabeçalho editorial da categoria */}
    <section class="max-w-7xl mx-auto px-6 lg:px-12 pt-16 lg:pt-24 pb-12">
      <div class="max-w-3xl mx-auto text-center">
        <span class="meta text-amber">Seção</span>
        <h1
          class="font-serif text-5xl sm:text-6xl lg:text-7xl leading-[1.02] mt-6 font-normal"
        >
          {category.title}
        </h1>
        <p class="font-serif italic text-xl lg:text-2xl leading-snug mt-6 text-ink/80">
          {category.description}
        </p>
        <div class="mx-auto mt-10 w-16 h-px bg-ink/30"></div>
      </div>
    </section>

    {/* Grid de posts da categoria */}
    <section class="max-w-7xl mx-auto px-6 lg:px-12">
      {
        posts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-y-14 md:gap-x-10 lg:gap-x-16 pb-20 lg:pb-24">
            {posts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        ) : (
          <div class="py-16 text-center">
            <p class="font-serif italic text-xl text-ink/70">
              Esta seção está sendo preparada.
            </p>
            <p class="meta mt-4">Volte em breve</p>
          </div>
        )
      }
    </section>
  </main>

  <Footer />
</Layout>
