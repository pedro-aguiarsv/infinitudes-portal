---
// =============================================================
// index.astro · Home do portal InFinitudes
// -------------------------------------------------------------
// Reproduz o wireframe editorial (benchmark: newyorker.com):
//   1. Header
//   2. HeroFeatured         ← ensaio de capa
//   3. Grid "Relatos & Podcasts da semana" (faixa com título)
//   4. BookSection          ← destaque do livro
//   5. LongEssayHighlight   ← amostra de ensaio longo
//   6. Footer (com newsletter)
//
// Dados vêm do Sanity. Enquanto o Studio está sendo alimentado,
// cada bloco cai em fake data editorial coerente (estado "vazio"
// tratado como estado apresentável).
// =============================================================
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PostCard from "../components/PostCard.astro";
import HeroFeatured, {
  type HeroContent,
} from "../components/HeroFeatured.astro";
import BookSection from "../components/BookSection.astro";
import LongEssayHighlight from "../components/LongEssayHighlight.astro";
import { getAllPosts, urlFor, type PostPreview } from "../lib/sanity";
import { getCategory } from "../lib/categories";

const posts = await getAllPosts();

const [featured, ...rest] = posts;
const gridPosts = rest.slice(0, 3);

// Hero: se houver post publicado, usa ele; senão, HeroFeatured cai no fake
const heroContent: HeroContent | undefined = featured
  ? {
      eyebrow: `${getCategory(featured.category ?? "")?.title ?? "Ensaio de capa"} · InFinitudes`,
      title: featured.title,
      dek: featured.excerpt,
      byline: null,
      readingTime: null,
      href: featured.category
        ? `/${featured.category}/${featured.slug}`
        : `/${featured.slug}`,
      imageUrl: featured.mainImage
        ? urlFor(featured.mainImage)
            .width(1400)
            .height(1750)
            .fit("crop")
            .auto("format")
            .url()
        : null,
      imageAlt: featured.mainImage?.alt ?? null,
      imageCaption: null,
    }
  : undefined;

// Fake data editorial para o grid (fiel ao wireframe). Os labels ricos
// ("Divã Infinito · Relato", "Hub Infinito · Podcast · Ep. 14") e o
// rodapé com autor+duração ("Marina Pires · 6 min") são passados via
// props do PostCard — por isso precisam ficar fora da struct de post.
type FakeCard = {
  post: PostPreview;
  categoryLabel: string;
  metaLabel: string;
};

const FAKE_GRID: FakeCard[] = [
  {
    post: {
      _id: "fake-1",
      title: "O que aprendi ao cuidar da minha mãe nos últimos meses",
      slug: "cuidar-da-minha-mae",
      publishedAt: new Date().toISOString(),
      mainImage: null,
      category: "diva-infinito",
      excerpt:
        "Quando a cura deixa de ser o objetivo, descobrimos que presença é a forma mais honesta de amor.",
    },
    categoryLabel: "Divã Infinito · Relato",
    metaLabel: "Marina Pires · 6 min",
  },
  {
    post: {
      _id: "fake-2",
      title: "Dor total: o que Cicely Saunders ainda tem a nos ensinar",
      slug: "dor-total-cicely-saunders",
      publishedAt: new Date().toISOString(),
      mainImage: null,
      category: "hub-infinito",
      excerpt:
        "Conversa com a enfermeira e pesquisadora Ana Lúcia Freire sobre o conceito que fundou o movimento hospice moderno.",
    },
    categoryLabel: "Hub Infinito · Podcast · Ep. 14",
    metaLabel: "Redação · 38 min de áudio",
  },
  {
    post: {
      _id: "fake-3",
      title: "Cartas de uma enfermeira de hospice nos anos 70",
      slug: "cartas-de-hospice",
      publishedAt: new Date().toISOString(),
      mainImage: null,
      category: "curadoria",
      excerpt:
        "Cinco documentos resgatados que revelam como o cuidado ao fim da vida mudou — e o que permanece intacto.",
    },
    categoryLabel: "Curadoria · Arquivo",
    metaLabel: "Arquivo InFinitudes · 12 min",
  },
];

const hasRealPosts = gridPosts.length > 0;
---

<Layout title="InFinitudes — Humanização na saúde e cuidados paliativos">
  <Header />

  <main>
    {/* 1 · Ensaio de capa · hero assimétrico 7/5 */}
    <HeroFeatured hero={heroContent} />

    {/* 2 · Faixa "Relatos & Podcasts da semana" + grid de 3 colunas */}
    <section class="max-w-7xl mx-auto px-6 lg:px-12 border-t border-rule">
      <div class="py-10 flex items-center gap-6">
        <span class="flex-1 h-px bg-rule"></span>
        <h2 class="meta">Relatos &amp; Podcasts da semana</h2>
        <span class="flex-1 h-px bg-rule"></span>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-3 gap-y-14 md:gap-x-10 lg:gap-x-16 pb-20 lg:pb-24"
      >
        {
          hasRealPosts
            ? gridPosts.map((post) => <PostCard post={post} />)
            : FAKE_GRID.map((item) => (
                <PostCard
                  post={item.post}
                  category={item.categoryLabel}
                  meta={item.metaLabel}
                />
              ))
        }
      </div>
    </section>

    {/* 3 · Box do livro · CTA → Lojinha */}
    <BookSection />

    {/* 4 · Ensaio longo em destaque · amostra do padrão editorial interno */}
    <LongEssayHighlight />
  </main>

  <Footer />
</Layout>
